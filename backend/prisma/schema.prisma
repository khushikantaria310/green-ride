generator client {
  provider               = "prisma-client"
  output                 = "./generated"
  // 🔥 Optimizing for your Bun + Cacy OS environment
  runtime                = "bun"
  moduleFormat           = "esm"
  importFileExtension    = "ts"
  generatedFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
  // Note: url is handled in your prisma.config.ts for Prisma 7
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String?       // 🔥 PHASE 4: Added for real Authentication
  balance      Float         @default(0.0)
  role         String        @default("OPERATOR")
  bookings     Booking[]
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

model Station {
  id                 String    @id @default(uuid())
  externalId         Int       @unique
  name               String
  address            String
  city               String
  state              String
  latitude           Float
  longitude          Float
  operatorName       String?
  availableBatteries Int       @default(4)
  status             String    @default("ACTIVE")
  bookings           Booking[]
  createdAt          DateTime  @default(now())
}

model Booking {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  station   Station  @relation(fields: [stationId], references: [id])
  stationId String
  status    String   @default("CONFIRMED")
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Transaction {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  amount    Float
  type      String   // TOPUP, WITHDRAW, BOOKING
  status    String   @default("SUCCESS")
  upiRef    String?
  createdAt DateTime @default(now())
}
